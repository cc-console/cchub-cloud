{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "cc-console",
  "version": "0.2.17",
  "identifier": "cloud.cchub.cc-console",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "cc-console",
        "width": 1100,
        "height": 720,
        "minWidth": 480,
        "minHeight": 560,
        "visible": false,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/cc-console"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
